# ============================================================
#  VALERIA — Environment Variables
# ============================================================

# ── Anthropic (Valeria AI) ────────────────────────────────
# Get this here console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZAR_CON_TU_KEY

# ── WhatsApp Business API (Meta) ─────────────────────────────
# Get this here developers.facebook.com → tu app → WhatsApp → API Setup

# Access Token (Get this here: developers.facebook.com → tu app → WhatsApp → API Setup → Generate Token)
WA_ACCESS_TOKEN=EAAxxxxx_REEMPLAZAR_CON_TU_TOKEN

# Phone Number ID (ID phone number of your WhatsApp Business Account)
# Ejemplo: 123456789012345
WA_PHONE_NUMBER_ID=REEMPLAZAR_CON_TU_PHONE_NUMBER_ID

# ── Webhook's security ────────────────────────────────────
# Example: dental_neiva_valeria_2024
# Use the same value, you can get it from here: Meta Developers → Webhooks
VERIFY_TOKEN=REEMPLAZAR_CON_TU_TOKEN_SECRETO

# ── Server ─────────────────────────────────────────────────
# Render.com asign PORT automatically — do not change this value
PORT=3000

# ── Banking info ─────────────────────────────
BANK_HOLDER_NAME="TEST NAME"
BANK_HOLDER_CC=123456789
BANCOLOMBIA_ACCOUNT=123
NEQUI_NUMBER=3150000000
DAVIVIENDA_ACCOUNT=444444
