# ============================================================
#  VALERIA — Variables de entorno
#  IMPORTANTE: Copia este archivo como ".env" y llena los valores
#  NUNCA subas el archivo ".env" a GitHub (ya está en .gitignore)
# ============================================================

# ── Anthropic (IA de Valeria) ────────────────────────────────
# Obtener en: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZAR_CON_TU_KEY

# ── WhatsApp Business API (Meta) ─────────────────────────────
# Obtener en: developers.facebook.com → tu app → WhatsApp → API Setup

# Access Token temporal (para pruebas) o permanente (producción)
WA_ACCESS_TOKEN=EAAxxxxx_REEMPLAZAR_CON_TU_TOKEN

# Phone Number ID (NO es el número de teléfono — es un ID largo)
# Ejemplo: 123456789012345
WA_PHONE_NUMBER_ID=REEMPLAZAR_CON_TU_PHONE_NUMBER_ID

# ── Seguridad del webhook ────────────────────────────────────
# Invéntalo tú — cualquier string secreto sin espacios
# Ejemplo: dental_neiva_valeria_2024
# Debes usar el MISMO valor aquí y en Meta Developers → Webhooks
VERIFY_TOKEN=REEMPLAZAR_CON_TU_TOKEN_SECRETO

# ── Servidor ─────────────────────────────────────────────────
# Render.com asigna PORT automáticamente — no lo cambies
PORT=3000
